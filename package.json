{
  "name": "discord-ai-ticket-bot",
  "version": "2.0.0",
  "description": "Production-grade AI-powered Discord Ticket System",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/index.ts",
    "deploy": "ts-node src/scripts/deploy-commands.ts",
    "dashboard:dev": "cd src/dashboard/frontend && npm run dev",
    "dashboard:build": "cd src/dashboard/frontend && npm run build"
  },
  "dependencies": {
    "discord.js": "^14.14.1",
    "@discordjs/rest": "^2.3.0",
    "discord-api-types": "^0.37.83",
    "mongoose": "^8.2.4",
    "openai": "^4.28.0",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "socket.io": "^4.7.4",
    "ioredis": "^5.3.2",
    "winston": "^3.12.0",
    "winston-daily-rotate-file": "^4.7.1",
    "uuid": "^9.0.1",
    "moment": "^2.30.1",
    "zod": "^3.22.4",
    "axios": "^1.6.8",
    "node-html-parser": "^6.1.13",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "typescript": "^5.4.2",
    "@types/node": "^20.11.24",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/uuid": "^9.0.8",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.2"
  }
}
